# Скопируй этот файл в .env.local и впиши свои ключи.
# anon-ключ ПУБЛИЧНЫЙ (можно в браузер). Остальные — СЕКРЕТНЫЕ, только сервер, не коммить!

# --- Публичные (идут в браузер) ---
NEXT_PUBLIC_SUPABASE_URL=https://xsnthzdhvkhwpvopyaqd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ВПИШИ_ANON_PUBLIC_КЛЮЧ

# --- Серверные секреты (только на сервере, НЕ в браузер, НЕ в git) ---
# Токен бота из @BotFather
TELEGRAM_BOT_TOKEN=ВПИШИ_ТОКЕН_БОТА
# Случайная строка для подписи сессий (сгенерируй: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))")
SESSION_SECRET=ВПИШИ_СЛУЧАЙНУЮ_СТРОКУ
# service_role ключ Supabase (Project Settings → API → service_role secret)
SUPABASE_SERVICE_ROLE_KEY=ВПИШИ_SERVICE_ROLE_КЛЮЧ
